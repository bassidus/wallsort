#!/bin/bash

RECURSIVE=false

# Parse optional -R flag
while getopts ":R" opt; do
    case $opt in
        R) RECURSIVE=true ;;
        *) ;;
    esac
done
shift $(( OPTIND - 1 ))

if [[ $# -ne 2 ]]; then
    echo "Usage: $(basename "$0") [-R] <source-dir> <target-dir>"
    echo
    echo "  -R          Recursively scan source-dir for images"
    echo "  source-dir  Directory containing unsorted wallpapers"
    echo "  target-dir  Directory where sorted subfolders will be created"
    exit 1
fi

SRC_DIR="$1"
OUT_DIR="$2"

# Capture CWD before cd-ing anywhere
INVOKE_DIR="$(pwd)"

# Resolve source directory
cd "$SRC_DIR" || { echo "Source directory not found: $SRC_DIR"; exit 1; }
SRC_DIR="$(pwd)"

# Resolve output directory relative to where the user invoked the script
[[ "$OUT_DIR" != /* ]] && OUT_DIR="$INVOKE_DIR/$OUT_DIR"
mkdir -p "$OUT_DIR" || { echo "Cannot create output directory: $OUT_DIR"; exit 1; }
OUT_DIR="$(cd "$OUT_DIR" && pwd)"

# Collect all matching image files
image_exts=( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \
             -o -iname "*.avif" -o -iname "*.jxl" -o -iname "*.tiff" -o -iname "*.tif" \
             -o -iname "*.bmp" )

if $RECURSIVE; then
    mapfile -d '' files < <(find "$SRC_DIR" -type f \( "${image_exts[@]}" \) -print0 | sort -z)
else
    mapfile -d '' files < <(find "$SRC_DIR" -maxdepth 1 -type f \( "${image_exts[@]}" \) -print0 | sort -z)
fi

total=${#files[@]}

if [[ $total -eq 0 ]]; then
    echo "No image files found in $SRC_DIR${RECURSIVE:+ (recursive)}."
    exit 0
fi

count=0
skipped=0

for file in "${files[@]}"; do
    (( count++ ))
    pct=$(( count * 100 / total ))
    display="${file#"$SRC_DIR/"}"

    # Overwrite the line in interactive terminals; fall back to plain output
    if [[ -t 1 ]]; then
        printf "\r[%3d%%] (%d/%d) %s\033[K" "$pct" "$count" "$total" "$display"
    else
        echo "[$pct%] ($count/$total) $display"
    fi

    # Get dimensions
    dimensions=$(identify -format "%w %h" "$file" 2>/dev/null)
    [[ -z "$dimensions" ]] && continue
    read -r width height <<< "$dimensions"

    # Determine main category (aspect ratio) via awk — no bc subshell
    dir=$(awk -v w="$width" -v h="$height" 'BEGIN {
        r = w / h
        if (r > 2.3)      print "Ultrawide"
        else if (r > 1.3) print "Widescreen"
        else               print "Other"
    }')

    # Determine subcategory (resolution)
    if   [ "$width" -ge 5120 ]; then subdir="Ultra_High_Res"
    elif [ "$width" -ge 3840 ]; then subdir="4K"
    elif [ "$width" -ge 2560 ]; then subdir="QHD"
    elif [ "$width" -ge 1920 ]; then subdir="FHD"
    elif [ "$width" -ge 1280 ]; then subdir="HD"
    else                              subdir="Small_Files"
    fi

    # Execute move — refuse to silently overwrite an existing file
    target_path="$OUT_DIR/$dir/$subdir"
    mkdir -p "$target_path"
    if ! mv --no-clobber "$file" "$target_path/"; then
        (( skipped++ ))
        printf "\n  Skipped (conflict): %s -> %s\n" "$display" "$target_path/"
    fi
done

echo   # newline after the progress line
echo "Sorting complete! ($total files processed, $skipped skipped due to name conflicts)"
echo "  Source: $SRC_DIR"
echo "  Output: $OUT_DIR"
