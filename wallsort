#!/bin/bash

RECURSIVE=false
MOVE_DUPES=false
PRUNE_EMPTY=false

while getopts ':Rde' opt; do
    case $opt in
        R) RECURSIVE=true ;;
        d) MOVE_DUPES=true ;;
        e) PRUNE_EMPTY=true ;;
        ?) echo "Unknown option: -$OPTARG"; exit 1 ;;
    esac
done
shift $(( OPTIND - 1 ))

if [[ $# -ne 2 ]]; then
    echo "Usage: $(basename "$0") [-Rde] <source-dir> <target-dir>"
    echo
    echo "  -R          Recursively scan source-dir for images"
    echo "  -d          Move duplicates to target-dir/Duplicates instead of leaving them"
    echo "  -e          Remove empty directories left in source-dir afterwards"
    echo "  source-dir  Directory containing unsorted wallpapers"
    echo "  target-dir  Directory where sorted subfolders will be created"
    exit 1
fi

SRC_DIR=$1
OUT_DIR=$2

INVOKE_DIR=$(pwd)

cd "$SRC_DIR" || { echo "Source directory not found: $SRC_DIR"; exit 1; }
SRC_DIR=$(pwd)

[[ $OUT_DIR != /* ]] && OUT_DIR=$INVOKE_DIR/$OUT_DIR
mkdir -p "$OUT_DIR" || { echo "Cannot create output directory: $OUT_DIR"; exit 1; }
OUT_DIR=$(cd "$OUT_DIR" && pwd)

image_exts=(
    -iname '*.jpg'  -o -iname '*.jpeg'
    -o -iname '*.png'  -o -iname '*.webp'
    -o -iname '*.avif' -o -iname '*.jxl'
    -o -iname '*.tiff' -o -iname '*.tif'
    -o -iname '*.bmp'
)

if $RECURSIVE; then
    mapfile -d '' files < <(find "$SRC_DIR" -type f \( "${image_exts[@]}" \) -print0 | sort -z)
else
    mapfile -d '' files < <(find "$SRC_DIR" -maxdepth 1 -type f \( "${image_exts[@]}" \) -print0 | sort -z)
fi

total=${#files[@]}

prune_empty_dirs() {
    $PRUNE_EMPTY || return 0
    local pruned=0 dir
    while IFS= read -r -d '' dir; do
        rmdir "$dir" 2>/dev/null && (( pruned++ ))
    done < <(find "$SRC_DIR" -mindepth 1 -name '.*' -prune -o -type d -print0 | sort -zr)
    (( pruned > 0 )) && echo "Removed $pruned empty director$( (( pruned == 1 )) && echo y || echo ies) in $SRC_DIR"
    return 0
}

if (( total == 0 )); then
    echo "No image files found in $SRC_DIR$($RECURSIVE && echo ' (recursive)')."
    prune_empty_dirs
    exit 0
fi

count=0 skipped=0 in_place=0 failed=0 dupes=0

for file in "${files[@]}"; do
    (( count++ ))
    display=${file#"$SRC_DIR/"}

    if [[ -t 1 ]]; then
        printf '\r[%3d%%] (%d/%d) %s\033[K' \
            $(( count * 100 / total )) "$count" "$total" "$display"
    else
        echo "[$(( count * 100 / total ))%] ($count/$total) $display"
    fi

    if ! read -r width height < <(identify -ping -format '%w %h\n' "$file[0]" 2>/dev/null); then
        (( failed++ ))
        printf '\n  failed to identify: %s\n' "$display"
        continue
    fi

    aspect=$(awk -v w="$width" -v h="$height" 'BEGIN {
        r = w / h
        if      (r > 2.3) print "Ultrawide"
        else if (r > 1.3) print "Widescreen"
        else               print "Other"
    }')

    if      (( width >= 5120 )); then res=Ultra_High_Res
    elif    (( width >= 3840 )); then res=4K
    elif    (( width >= 2560 )); then res=QHD
    elif    (( width >= 1920 )); then res=FHD
    elif    (( width >= 1280 )); then res=HD
    else                              res=Small_Files
    fi

    dest=$OUT_DIR/$aspect/$res
    if [[ $(dirname "$file") == "$dest" ]]; then
        (( in_place++ ))
        continue
    fi

    mkdir -p "$dest"
    if [[ -e $dest/${file##*/} ]]; then
        if cmp -s "$file" "$dest/${file##*/}"; then
            if $MOVE_DUPES; then
                dup_dir=$OUT_DIR/Duplicates
                mkdir -p "$dup_dir"
                base=${file##*/}
                target=$dup_dir/$base
                n=1
                while [[ -e $target ]]; do
                    target=$dup_dir/${base%.*}_$n.${base##*.}
                    (( n++ ))
                done
                mv "$file" "$target"
                (( dupes++ ))
                printf '\n  duplicate: %s -> %s\n' "$display" "$target"
            else
                (( skipped++ ))
                printf '\n  skipped (duplicate): %s\n' "$display"
            fi
        else
            (( skipped++ ))
            printf '\n  skipped (name conflict): %s -> %s/\n' "$display" "$dest"
        fi
        continue
    fi
    mv --no-clobber "$file" "$dest/"
done

echo

prune_empty_dirs

echo "Done. $total scanned, $in_place already sorted, $skipped conflicts, $dupes duplicates moved, $failed failed to identify."
echo "  src: $SRC_DIR"
echo "  out: $OUT_DIR"
